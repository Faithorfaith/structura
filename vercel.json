{
  "version": 2,
  "functions": {
    "api/screenshot.js": { "memory": 512, "maxDuration": 30 },
    "api/convert.js":    { "memory": 512, "maxDuration": 30 },
    "api/parse.js":      { "memory": 512, "maxDuration": 30 }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin",  "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "POST, GET, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ]
}
